<Window x:Class="Magazine.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Magazine"
        mc:Ignorable="d" Style="{StaticResource Window}"
        Title="Products" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Rectangle Fill="#7FFF00"/>
        <TextBlock Text="Магазин обуви"
                   FontSize="50"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" BorderBrush="Black" BorderThickness="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="80"
                                        Height="80"
                                        Margin="15 0">
                                    <Image Source="{Binding Photo}"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Category.Category1}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding ProductType.ProductType1}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Discription, StringFormat='Описание: {0}'}"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Producer.Producer1, StringFormat='Производитель: {0}'}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Supplier.Supplier1, StringFormat='Поставщик: {0}'}"/>
                                    <TextBlock Text="{Binding Price, StringFormat='Цена: {0} руб.'}"/>
                                    <TextBlock Text="{Binding Unit.Unit1, StringFormat='Единица измерения: {0}'}"/>
                                    <TextBlock Text="{Binding QuantityInStock, StringFormat='Количество на складе: {0} шт.'}"/>
                                </StackPanel>
                                <Border Grid.Column="2" VerticalAlignment="Center" Margin="0 0 30 0">
                                    <TextBlock Text="{Binding Discount, StringFormat='Скидка: {0}%'}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Button x:Name="LogOutButton"
                Content="Выйти"
                Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Margin="20 10"/>
    </Grid>
</Window>
