<Window x:Class="Magazine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Magazine"
        mc:Ignorable="d" Style="{StaticResource Window}"
        Title="Autorization" Height="450" Width="800">
    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="60">
                <TextBlock Text="Авторизация"
                           Margin="40 10"
                           FontWeight="SemiBold"
                           FontSize="25"/>
                <TextBlock Text="Логин"
                           Margin="18 0 0 0"
                           FontSize="15"/>
                <TextBox x:Name="LoginEnter"
                         Margin="20 10"/>
                <TextBlock Text="Пароль"
                           Margin="18 0 0 0"
                           FontSize="15"/>
                <PasswordBox x:Name="PasswordEnter"
                             Margin="20 10"/>
                <Button x:Name="LogInButton"
                        Content="Войти"
                        Margin="20 10"
                        FontWeight="SemiBold"
                        Click="LogInButton_Click"/>
                <TextBlock HorizontalAlignment="Center"
                           Text="Войти как гость"
                           FontSize="15"
                           FontWeight="SemiBold"
                           MouseDown="TextBlock_MouseDown"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
